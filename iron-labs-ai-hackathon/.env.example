# IronLabs Hackathon — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Primary API key (ironaai SDK)
IRONAAI_API_KEY=your_ironaai_api_key_here

# Legacy fallback — used if IRONAAI_API_KEY is not set
IronLabs_API_KEY=your_ironlabs_api_key_here
